{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/labguru/main/json-schema/createRequestTemplate.json",
  "title": "createRequestTemplate",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string",
      "example": "YOUR TOKEN IS HERE"
    },
    "item": {
      "type": "object",
      "required": [
        "request_type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the request template"
        },
        "request_type": {
          "type": "string",
          "description": "The type of request"
        }
      }
    }
  }
}