{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/labguru/main/json-schema/startRequest.json",
  "title": "startRequest",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string",
      "example": "YOUR TOKEN IS HERE"
    },
    "item": {
      "type": "object",
      "properties": {
        "performed_by": {
          "type": "integer",
          "description": "The ID of the member which will perform the request"
        }
      }
    }
  }
}