{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/labguru/main/json-schema/createFolder.json",
  "title": "createFolder",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string",
      "example": "YOUR TOKEN IS HERE"
    },
    "item": {
      "type": "object",
      "required": [
        "project_id",
        "title"
      ],
      "properties": {
        "project_id": {
          "type": "integer",
          "description": "The ID of the project"
        },
        "title": {
          "type": "string",
          "description": "The folder title"
        }
      }
    }
  }
}