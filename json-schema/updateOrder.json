{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/labguru/main/json-schema/updateOrder.json",
  "title": "updateOrder",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string",
      "example": "YOUR TOKEN IS HERE"
    },
    "item": {
      "type": "object",
      "properties": {
        "price": {
          "type": "number",
          "format": "float",
          "description": "price"
        },
        "budget": {
          "type": "string",
          "description": "budget"
        },
        "currency": {
          "type": "integer",
          "description": "0 = NIS, 1 = DOLLAR, 2 = EURO, 3 = POUND, 4 = NOK "
        },
        "quantity": {
          "type": "integer",
          "description": "quantity"
        },
        "order_number": {
          "type": "integer",
          "description": "order number"
        },
        "description": {
          "type": "string",
          "description": "description"
        }
      }
    }
  }
}