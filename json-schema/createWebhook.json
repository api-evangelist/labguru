{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/labguru/main/json-schema/createWebhook.json",
  "title": "createWebhook",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string",
      "example": "YOUR TOKEN IS HERE"
    },
    "item": {
      "type": "object",
      "required": [
        "trigger_key",
        "active",
        "url"
      ],
      "properties": {
        "trigger_key": {
          "type": "string",
          "description": "trigger key",
          "example": "knowledgebase_document.signed"
        },
        "active": {
          "type": "boolean",
          "description": "by default it's false",
          "example": false
        },
        "url": {
          "type": "string",
          "description": "url",
          "example": "https://prod-flow.labguru.com/flows/1234567/flow_runs.json"
        }
      }
    }
  }
}